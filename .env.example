# ─────────────────────────────────────────────────────────────────────────
# Job Automation Agent — environment variables
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# Never commit .env to git (it's already in .gitignore).
#
# For the GitHub Actions cloud pipeline, these same names are set as repo
# secrets instead — see SETUP.md.
# ─────────────────────────────────────────────────────────────────────────

# ── LLM tailoring — Groq tried first, Gemini as fallback ───────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — comma-separated rotating-proxy URLs for jobspy. Leave unset
# unless you've bought a proxy plan; no free option reliably helps here.
PROXIES=

# ── Emails ──────────────────────────────────────────────────────────────────
JOB_EMAIL=yourname.jobs@gmail.com
NOTIFY_EMAIL=you@gmail.com

# ── Candidate info (used in the resume-tailoring profile) ──────────────────
FIRST_NAME=Jane
LAST_NAME=Doe
PHONE=+91-9999999999
LINKEDIN_URL=https://linkedin.com/in/yourprofile
GITHUB_URL=https://github.com/yourusername
YEARS_EXP=3
SALARY_LPA=25
MIN_SALARY_LPA=20
EXPERIENCE_LEVEL=mid

# ── Local-only apply.py/applier.py tool (not used by the cloud pipeline) ───
# NopeCHA (CAPTCHA solving, 50 free/day) — https://nopecha.com
NOPECHA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
